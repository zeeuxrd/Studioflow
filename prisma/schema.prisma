// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------
// ENUMS
// ------------------------------------------------------

enum TonePreference {
  casual
  professional
  educational
}

enum PlatformType {
  TikTok
  X
  Instagram
  LinkedIn
}

enum MonetizationGoal {
  grow_audience
  make_money
  stay_consistent
}

enum IdeaStatus {
  saved
  used
  archived
}

enum PostStatus {
  draft
  exported
  posted
}

enum ProductType {
  ebook
  checklist
  course
  template
}

enum ProductStatus {
  draft
  published
}

enum ConversionType {
  product_creation
  purchase
}

enum PlanTier {
  free
  starter
  creator
  pro
}

enum SubscriptionStatus {
  pending
  active
  cancelled
  expired
  past_due
}

// ------------------------------------------------------
// MODELS
// ------------------------------------------------------

model User {
  id            String            @id @default(uuid())
  name          String?
  email         String?           @unique
  emailVerified DateTime?
  image         String?
  password      String?
  niche         String?
  plan              PlanTier          @default(free)
  tone_preference   TonePreference    @default(casual)
  platform_focus    PlatformType      @default(X)
  monetization_goal MonetizationGoal  @default(grow_audience)
  created_at        DateTime          @default(now())

  ideas             ContentIdea[]
  trackingEvents    MonetizationTracking[]
  accounts          Account[]
  sessions          Session[]
  subscription      Subscription?
  usageRecords      UsageRecord[]
}

model Subscription {
  id                            String             @id @default(uuid())
  user_id                       String             @unique
  plan                          PlanTier
  status                        SubscriptionStatus @default(active)
  billing_period                String             @default("monthly")
  flutterwave_subscription_id   String?            @unique
  flutterwave_plan_id           String?
  flutterwave_tx_ref            String?
  current_period_start          DateTime
  current_period_end            DateTime
  created_at                    DateTime           @default(now())
  updated_at                    DateTime           @updatedAt

  user                          User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model UsageRecord {
  id               String   @id @default(uuid())
  user_id          String
  period_start     DateTime
  generations_count Int     @default(0)
  created_at       DateTime @default(now())

  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, period_start])
}

model ContentIdea {
  idea_id    String      @id @default(uuid())
  user_id    String
  niche      String
  idea_text  String
  category   String
  status     IdeaStatus  @default(saved)
  created_at DateTime    @default(now())

  user       User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  posts      ContentPost[]
}

model ContentPost {
  post_id                     String      @id @default(uuid())
  idea_id                     String
  platform_type               PlatformType
  content_body                String
  engagement_prediction_score Float?
  status                      PostStatus  @default(draft)
  refinement_history          Json        @default("[]")

  idea                        ContentIdea         @relation(fields: [idea_id], references: [idea_id], onDelete: Cascade)
  products                    ProductDefinition[]
}

model ProductDefinition {
  product_id                    String        @id @default(uuid())
  source_post_id                String
  product_type                  ProductType
  title                         String
  content_structure             Json
  monetization_price_suggestion Float
  full_content                  Json?
  status                        ProductStatus @default(draft)
  refinement_history            Json          @default("[]")

  source_post                   ContentPost   @relation(fields: [source_post_id], references: [post_id], onDelete: Cascade)
  transactions                  Transaction[]
}

model Transaction {
  transaction_id String   @id
  reference      String   @unique
  product_id     String
  buyer_email    String
  amount         Float
  currency       String   @default("USD")
  status         String   @default("pending")
  download_token String?  @unique
  downloaded_at  DateTime?
  created_at     DateTime @default(now())

  product        ProductDefinition @relation(fields: [product_id], references: [product_id])
}

model MonetizationTracking {
  tracking_id      String         @id @default(uuid())
  user_id          String
  content_id       String
  conversion_type  ConversionType
  revenue_estimate Float?
  created_at       DateTime       @default(now())

  user             User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Account {
  id              String  @id @default(cuid())
  userId          String
  type            String
  provider        String
  providerAccountId String
  refresh_token   String? @db.Text
  access_token    String? @db.Text
  expires_at      Int?
  token_type      String?
  scope           String?
  id_token        String? @db.Text
  session_state   String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
